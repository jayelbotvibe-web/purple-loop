# Pinned versions — the single source of truth for reproducible builds.
# Bumping a version is a deliberate, reviewed change (one commit, CI must stay green).
WAZUH_VERSION=4.9.2
WAZUH_DOCKER_REF=v4.9.2
CERTS_GENERATOR_IMAGE=wazuh/wazuh-certs-generator:0.0.2
GO_VERSION=1.22
UBUNTU_TAG=22.04
INDEXER_HEAP=-Xms4g -Xmx4g
INDEXER_MEM_LIMIT=8g
LAB_NETWORK=single-node_default
# Atomic Red Team is pinned at fetch time; scripts/lab-fetch.sh records the
# exact commit into mappings/atomic-red-team.commit so runs are reproducible.
